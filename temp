import os
import tkinter as tk

# 1. Define your Pygame Zero window dimensions
WIDTH = 800
HEIGHT = 600

# 2. Get your monitor's actual width using tkinter
root = tk.Tk()
monitor_width = root.winfo_screenwidth()
root.destroy()

# 3. Calculate the X coordinate for the top-right corner
# (Monitor Width minus the Pygame Zero Window Width)
spawn_x = monitor_width - WIDTH
spawn_y = 0  # 0 is the very top of the screen

# 4. Set the environment variable BEFORE importing pgzrun
os.environ['SDL_VIDEO_WINDOW_POS'] = f"{spawn_x},{spawn_y}"

import pgzrun

def draw():
    screen.clear()
    screen.draw.text("Snapped to Top-Right!", (20, 20), color="white")

pgzrun.go()